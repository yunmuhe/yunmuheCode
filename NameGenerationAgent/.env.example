# 应用配置
SECRET_KEY=replace-with-a-random-secret-key
DEBUG=True
LOG_LEVEL=INFO

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite 数据库配置
SQLITE_DATABASE_PATH=data/name_generation_agent.db

# 缓存配置
CACHE_TTL=3600
MAX_CACHE_SIZE=1000

# 请求配置
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1

# 姓名生成配置
DEFAULT_NAME_COUNT=5
MAX_NAME_COUNT=20
MIN_DESCRIPTION_LENGTH=5

# 管理员账号初始化（可选）
ADMIN_PHONE=
ADMIN_PASSWORD=

# 阿里云百炼 API
ALIYUN_API_KEY=

# 硅基流动 API
SILICONFLOW_API_KEY=

# 派欧云 API
PAIOU_API_KEY=

# 白山智算 API
BAISHAN_API_KEY=

# Aistudio API
AISTUDIO_API_KEY=
AISTUDIO_API_URL=
AISTUDIO_MODEL=
AISTUDIO_MAX_TOKENS=2000
